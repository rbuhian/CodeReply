# ============================================================================
# CodeReply BYOD - Git Ignore Configuration
# ============================================================================
# Author: Stuart (Project Manager)
# Date: April 3, 2026
# Description: Prevent sensitive and generated files from being committed
# ============================================================================

# ============================================================================
# Environment Variables (CRITICAL - Never commit!)
# ============================================================================
.env
.env.local
.env.development
.env.test
.env.production
*.env

# Keep .env.example for documentation
!.env.example

# ============================================================================
# Node.js Dependencies
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
pnpm-debug.log*

# Package manager lock files (optional - team can decide)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# ============================================================================
# Build Outputs
# ============================================================================
dist/
build/
out/
.next/
*.tsbuildinfo

# Backend build
src/backend/dist/
src/backend/build/

# Web build
src/web/dist/
src/web/build/

# Android build
src/android/build/
src/android/.gradle/
src/android/local.properties
src/android/.idea/
src/android/*.iml
src/android/.cxx/
src/android/app/build/
src/android/app/release/
*.apk
*.aab
*.ap_

