# ============================================================================
# CodeReply Backend API - Test Environment Configuration
# ============================================================================
# Copy this file to .env.test for running tests
# DO NOT commit .env.test to version control!
# ============================================================================

# ============================================================================
# Server Configuration
# ============================================================================
NODE_ENV=test
PORT=3000
LOG_LEVEL=error
CORS_ORIGIN=*

# ============================================================================
# Test Database Configuration (PostgreSQL)
# ============================================================================
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_NAME=codereply_test
TEST_DB_USER=postgres
TEST_DB_PASSWORD=postgres

# Database connection pool settings (smaller for tests)
DB_POOL_MAX=5
DB_POOL_MIN=1
DB_IDLE_TIMEOUT=10000
DB_CONNECTION_TIMEOUT=5000
DB_STATEMENT_TIMEOUT=10000

# ============================================================================
# Redis Configuration (Optional for tests)
# ============================================================================
REDIS_URL=redis://localhost:6379/1
REDIS_PASSWORD=
REDIS_CONNECT_TIMEOUT=5000

# ============================================================================
# JWT Configuration (Test values only)
# ============================================================================
JWT_SECRET=test_jwt_secret_key_not_for_production_use_only
JWT_EXPIRES_IN=365d

# ============================================================================
# API Keys (Test values)
# ============================================================================
API_KEY_SALT_ROUNDS=4

# ============================================================================
# Message Queue Configuration (Not used in unit tests)
# ============================================================================
QUEUE_NAME=codereply-messages-test
QUEUE_CONCURRENCY=1

# ============================================================================
# WebSocket Configuration (Sprint 2)
# ============================================================================
WS_PORT=3002
WS_HEARTBEAT_INTERVAL=5000

# ============================================================================
# Webhook Configuration
# ============================================================================
WEBHOOK_TIMEOUT=5000
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAYS=100,200,400

# ============================================================================
# Message Retry Configuration
# ============================================================================
MESSAGE_MAX_RETRIES=3
MESSAGE_RETRY_DELAYS=1000,2000,4000
MESSAGE_TTL_SECONDS=3600

# ============================================================================
# Rate Limiting (Disabled for tests)
# ============================================================================
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=1000

# ============================================================================
# Logging Configuration
# ============================================================================
LOG_DIR=./logs/test
ENABLE_FILE_LOGGING=false

# ============================================================================
# Feature Flags (All enabled for testing)
# ============================================================================
ENABLE_WEBHOOKS=true
ENABLE_ANALYTICS=false

# ============================================================================
# Test-Specific Configuration
# ============================================================================
# Test timeout (Jest)
TEST_TIMEOUT=30000

# Mock external services in tests
MOCK_WEBHOOKS=false
MOCK_SMS_SENDING=true

# Test data cleanup
AUTO_CLEANUP_TEST_DATA=true
